# 服务名称（用于健康检查展示）
SERVICE_NAME=public-japan-travel-ai

# 服务监听端口：你的服务器对外地址为 115.159.221.212:1217
PORT=8000

# 你的模型服务配置（以下三项最重要）
MODEL_PROVIDER=openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
MODEL_NAME=gpt-4o-mini

# 模型生成参数
MODEL_TEMPERATURE=0.4
MODEL_MAX_TOKENS=3000
REQUEST_TIMEOUT=60
STREAM_TIMEOUT=90

# CORS：建议填你的前端域名；调试期可使用 *
CORS_ALLOW_ORIGINS=*

# 某些供应商需要额外 Header（例如 OpenRouter 的 HTTP-Referer / X-Title）
# 不需要时保持 {}
OPENAI_EXTRA_HEADERS={}
